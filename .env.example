# Environment Configuration
# Copy this file to .env and fill in the values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Sentry Configuration (Error Tracking & Monitoring)
# Get your DSN from https://sentry.io/
VITE_SENTRY_DSN=

# App Version (for Sentry releases)
VITE_APP_VERSION=1.0.0

# OpenTelemetry Configuration (Distributed Tracing)
# Set to 'true' to enable OpenTelemetry
VITE_ENABLE_OTEL=false
# OTLP endpoint (e.g., http://localhost:4318 for local collector)
VITE_OTEL_ENDPOINT=

# Feature Flags
VITE_ENABLE_PWA=false
